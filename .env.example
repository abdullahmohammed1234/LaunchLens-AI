# MySQL connection string
DATABASE_URL="mysql://user:password@localhost:3306/launchlens"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# App URL (used by Auth.js in production)
AUTH_URL="http://localhost:3000"

# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Gemini model (default: gemini-2.5-flash). gemini-2.0-flash is deprecated.
# Free tier options: gemini-2.5-flash, gemini-2.5-flash-lite
GEMINI_MODEL="gemini-2.5-flash"
