generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  active
  archived
}

enum ExperienceLevel {
  beginner
  intermediate
  advanced
  expert
}

enum ActivityType {
  project_created
  project_updated
  project_analyzed
  simulation_generated
  roadmap_updated
  team_plan_created
  report_generated
  snapshot_created
  goal_created
  goal_completed
  mentor_conversation
}

enum MentorMode {
  project
  portfolio
  founder_coach
}

enum MentorTopic {
  general
  health
  what_if
  execution
  strategy
  portfolio
}

enum NotificationType {
  risk_increased
  team_readiness_dropped
  project_more_viable
  launch_readiness_improved
  goal_progress
  attention_required
}

enum GoalType {
  readiness_score
  risk_reduction
  launch_mvp
  custom
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  password            String
  image               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  projects            Project[]
  projectComparisons  ProjectComparison[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  goals               Goal[]
  projectSnapshots    ProjectSnapshot[]
  mentorConversations MentorConversation[]
}

model Project {
  id              String           @id @default(cuid())
  userId          String
  title           String
  description     String           @db.Text
  budget          String
  timeline        String
  teamSize        Int
  experienceLevel ExperienceLevel
  status          ProjectStatus    @default(draft)
  isStarred       Boolean          @default(false)
  isPinned        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses            Analysis[]
  failureSimulations  FailureSimulation[]
  roadmaps            Roadmap[]
  teamPlans           TeamPlan[]
  executiveReports    ExecutiveReport[]
  snapshots           ProjectSnapshot[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  goals               Goal[]
  mentorConversations MentorConversation[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, isStarred])
  @@index([userId, isPinned])
}

model Analysis {
  id                   String   @id @default(cuid())
  projectId            String
  successScore         Int
  riskLevel            String
  complexity           String
  estimatedTimelineMin Int
  estimatedTimelineMax Int
  skillGaps            Json
  blockers             Json
  recommendations      Json
  mvpScope             Json
  createdAt            DateTime @default(now())
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
}

model FailureSimulation {
  id              String   @id @default(cuid())
  projectId       String
  simulationData  Json
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
}

model Roadmap {
  id                      String   @id @default(cuid())
  projectId               String
  estimatedDurationMonths Int
  roadmapData             Json
  createdAt               DateTime @default(now())
  project                 Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
}

model TeamPlan {
  id                  String   @id @default(cuid())
  projectId           String
  recommendedTeamSize Int
  teamData            Json
  createdAt           DateTime @default(now())
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
}

model ProjectComparison {
  id             String   @id @default(cuid())
  userId         String
  projectIds     Json
  comparisonData Json
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model ExecutiveReport {
  id                       String        @id @default(cuid())
  projectId                String
  reportData               Json
  investmentReadinessScore Int
  createdAt                DateTime      @default(now())
  project                  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shares                   ReportShare[]

  @@index([projectId])
  @@index([projectId, createdAt])
}

model ReportShare {
  id        String          @id @default(cuid())
  reportId  String
  token     String          @unique
  expiresAt DateTime?
  createdAt DateTime        @default(now())
  report    ExecutiveReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([token])
}

model ProjectSnapshot {
  id           String   @id @default(cuid())
  projectId    String
  userId       String
  label        String?
  snapshotData Json
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([projectId, createdAt])
}

model ActivityLog {
  id          String       @id @default(cuid())
  userId      String
  projectId   String?
  type        ActivityType
  title       String
  description String?      @db.Text
  metadata    Json?
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([projectId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  projectId String?
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  projectId    String?
  type         GoalType
  title        String
  description  String?   @db.Text
  targetValue  Int?
  currentValue Int       @default(0)
  targetDate   DateTime?
  isCompleted  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([userId, isCompleted])
}

model MentorConversation {
  id        String         @id @default(cuid())
  userId    String
  projectId String?
  title     String
  mode      MentorMode     @default(project)
  topic     MentorTopic    @default(general)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  MentorMessage[]

  @@index([userId])
  @@index([userId, projectId])
  @@index([userId, createdAt])
  @@index([userId, topic])
}

model MentorMessage {
  id             String             @id @default(cuid())
  conversationId String
  role           String
  content        String             @db.Text
  responseData   Json?
  createdAt      DateTime           @default(now())
  conversation   MentorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}
